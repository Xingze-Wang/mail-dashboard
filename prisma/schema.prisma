generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Email {
  id          String   @id @default(cuid())
  from        String
  to          String
  subject     String
  html        String
  text        String?
  resendId    String?  @unique
  status      String   @default("queued") // queued, sent, delivered, opened, clicked, bounced, complained
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Thread support
  inReplyTo   String?  // Message-ID of the email being replied to
  references  String?  // Full References header chain
  messageId   String?  @unique // Message-ID assigned by Resend
  threadId    String?  // Group emails into threads

  events      WebhookEvent[]

  @@index([threadId])
  @@index([to])
  @@index([status])
  @@index([createdAt])
}

model InboundEmail {
  id          String   @id @default(cuid())
  from        String
  to          String
  subject     String
  html        String?
  text        String?
  messageId   String?  @unique
  inReplyTo   String?
  references  String?
  threadId    String?
  headers     String?  // JSON string of all headers
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([threadId])
  @@index([from])
  @@index([createdAt])
}

model Template {
  id          String   @id @default(cuid())
  name        String
  subject     String
  html        String
  text        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WebhookEvent {
  id          String   @id @default(cuid())
  emailId     String?
  email       Email?   @relation(fields: [emailId], references: [id])
  type        String   // email.sent, email.delivered, email.opened, email.clicked, email.bounced, email.complained
  payload     String   // Full JSON payload
  createdAt   DateTime @default(now())

  @@index([emailId])
  @@index([type])
  @@index([createdAt])
}

model ApiKey {
  id          String   @id @default(cuid())
  name        String
  key         String   @unique
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime?
}

// ──────────────────────────────────────────────
// VC Lead Scouting — Dedup & Freshness Models
// ──────────────────────────────────────────────

model Lead {
  id            String   @id @default(cuid())
  platform      String   // jike, xiaohongshu, v2ex, weibo, producthunt
  platformId    String   // platform-specific user ID
  authorName    String
  companyName   String?
  productUrl    String?
  contactEmail  String?
  contactWechat String?
  githubUrl     String?
  linkedinUrl   String?
  stage         String?  // idea, mvp, launched, revenue
  score         Int      @default(0) // 1-5 qualification score
  teamRating    String?  // hot, interesting, noise, outreach_sent
  firstSeenAt   DateTime @default(now())
  lastSeenAt    DateTime @default(now())
  lastActiveAt  DateTime? // when they last posted something new
  contactedAt   DateTime?
  contactMethod String?  // email, wechat, dm
  responseAt    DateTime?
  responseType  String?  // positive, negative, no_response
  notes         String?

  // Link to email outreach
  emailId       String?

  sightings     LeadSighting[]

  @@unique([platform, platformId])
  @@index([score])
  @@index([firstSeenAt])
  @@index([teamRating])
}

model LeadSighting {
  id          String   @id @default(cuid())
  leadId      String
  lead        Lead     @relation(fields: [leadId], references: [id])
  runDate     DateTime @default(now())
  postUrl     String
  postTitle   String?
  postContent String?
  likes       Int      @default(0)
  comments    Int      @default(0)
  topic       String?
  keyword     String?  // which search keyword found this

  @@index([leadId])
  @@index([runDate])
}

model ScoutRun {
  id              String   @id @default(cuid())
  runDate         DateTime @default(now())
  platformsUsed   String   // comma-separated
  totalRaw        Int
  totalQualified  Int
  totalNew        Int      // first-time leads
  totalReturning  Int      // seen before
  keywordsUsed    String?  // JSON
  notes           String?
}
